{
  "redis": {
    "addr": "redis.example.com:6379",
    "username": "",
    "password": "",
    "db": 0
  },
  "queues": {
    "taskQueue": "oddjob:tasks",
    "poppitQueue": "poppit:commands"
  },
  "poppit": {
    "repo": "its-the-vibe/OddJob",
    "branch": "refs/heads/main",
    "dir": "${basedir}",
    "type": "odd:job",
    "outputChannel": "poppit:output"
  },
  "poll": {
    "intervalSeconds": 1
  },
  "aliases": {
    "basedir": "/workspace",
    "orgname": "its-the-vibe",
    "stmtdate": "/path/to/stmtdate",
    "stmtpng2tsv": "/path/to/stmtpng2tsv",
    "stmt2redis": "/path/to/stmt2redis"
  }
}
