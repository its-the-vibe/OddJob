{
  "redis": {
    "addr": "redis.example.com:6379",
    "username": "",
    "password": "",
    "db": 0
  },
  "queues": {
    "taskQueue": "oddjob:tasks",
    "poppitQueue": "poppit:commands"
  },
  "poppit": {
    "repo": "its-the-vibe/OddJob",
    "branch": "refs/heads/main",
    "dir": "${basedir}",
    "type": "odd:job",
    "outputChannel": "poppit:output"
  },
  "poll": {
    "intervalSeconds": 1
  },
  "aliases": {
    "basedir": "/workspace",
    "command1": "/path/to/command1/command1",
    "command2": "/path/to/command2/command2"
  }
}
